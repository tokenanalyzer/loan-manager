# =================================================================
# Loan Manager Enterprise — Root Environment Variables (Example)
# Copy this file to `.env` and fill in real values for local dev.
# Per-app overrides live in apps/*/.env.example — copy those too.
# NEVER commit a real `.env` file.
# =================================================================

# --- General ---
NODE_ENV=development
APP_NAME=loan-manager-enterprise
TZ=UTC

# --- PostgreSQL ---
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=loanmanager
POSTGRES_PASSWORD=changeme
POSTGRES_DB=loan_manager_dev
DATABASE_URL=postgresql://loanmanager:changeme@localhost:5432/loan_manager_dev

# --- Backend (NestJS) ---
BACKEND_PORT=3000
BACKEND_HOST=0.0.0.0
API_PREFIX=api

# --- Admin Panel (React + Vite) ---
ADMIN_PANEL_PORT=5173
VITE_API_BASE_URL=http://localhost:3000/api

# --- Firebase (shared project config) ---
FIREBASE_PROJECT_ID=
FIREBASE_API_KEY=
FIREBASE_AUTH_DOMAIN=
FIREBASE_STORAGE_BUCKET=
FIREBASE_MESSAGING_SENDER_ID=
FIREBASE_APP_ID=

# --- Firebase Admin SDK (backend only) ---
FIREBASE_ADMIN_CLIENT_EMAIL=
FIREBASE_ADMIN_PRIVATE_KEY=
FIREBASE_ADMIN_PROJECT_ID=

# --- Firebase Cloud Messaging ---
FCM_SERVER_KEY=
FCM_VAPID_KEY=
