# Backend (NestJS) — local environment example
NODE_ENV=development
BACKEND_PORT=3000
BACKEND_HOST=0.0.0.0
API_PREFIX=api
CORS_ORIGIN=*
LOG_LEVEL=debug

DATABASE_URL=postgresql://loanmanager:changeme@localhost:5432/loan_manager_dev
DATABASE_SSL=false
DATABASE_LOGGING=false
DATABASE_MAX_CONNECTIONS=10

# Set to true only once real Firebase Admin credentials are provided below.
# When false (default), FirebaseAdminModule no-ops and the backend still
# starts successfully.
FIREBASE_ENABLED=false
FIREBASE_ADMIN_PROJECT_ID=
FIREBASE_ADMIN_CLIENT_EMAIL=
FIREBASE_ADMIN_PRIVATE_KEY=

# Local file storage (Phase 6 — Documents). Swap for a real object
# store (Firebase Storage, S3, etc.) via StorageService later.
UPLOADS_DIR=./uploads
