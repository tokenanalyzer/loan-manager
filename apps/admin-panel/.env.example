# Admin Panel (React + Vite) — local environment example
ADMIN_PANEL_PORT=5173
VITE_API_BASE_URL=http://localhost:3000/api

# Set to true only once real Firebase project values are provided below.
# When false (default), the login page shows a "not configured" state
# instead of calling an uninitialized Firebase SDK.
VITE_FIREBASE_ENABLED=false
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
